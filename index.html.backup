<!doctype html>
<html lang="en">
	<head>
		<meta name="description" content="YT Studio - Islamic history and Quranic mysteries" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Ruh Al Tarikh | Cinematic Islamic Archive</title>
		<meta
			name="description"
			content="A cinematic archive for Ruh Al Tarikh episodes exploring Islamic history, scripture, prophecy, and deep discussion."
		/>
		<meta name="author" content="Ruh Al Tarikh" />
		<meta property="og:title" content="Ruh Al Tarikh" />
		<meta property="og:description" content="Uncovering truth through Islamic history, scripture, and contested ideas." />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />

		<!-- Preconnects for performance -->
		<link rel="preconnect" href="https://i.ytimg.com" />
		<link rel="preconnect" href="https://www.youtube.com" />
		<link rel="preconnect" href="https://yt-studio.ruhdevopsytstudio.workers.dev" />
		<link rel="dns-prefetch" href="https://yt-studio.ruhdevopsytstudio.workers.dev" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Manrope:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link rel="stylesheet" href="css/style.css" />
		<!-- Creator Studio Modules CSS -->
		<link rel="stylesheet" href="css/editor.css" />
		<link rel="stylesheet" href="css/research.css" />
		<link rel="stylesheet" href="css/ai.css" />
		<link rel="stylesheet" href="css/seo.css" />
		<link rel="stylesheet" href="css/voice.css" />
		<link rel="stylesheet" href="css/repurpose.css" />
		<link rel="stylesheet" href="css/dashboard.css" />
		<link rel="stylesheet" href="css/islamic.css" />
		<link rel="stylesheet" href="css/planner.css" />
		<!-- Vercel Speed Insights & Analytics -->
		<script>
			window.si =
				window.si ||
				function () {
					(window.siq = window.siq || []).push(arguments);
				};
			window.va =
				window.va ||
				function () {
					(window.vaq = window.vaq || []).push(arguments);
				};
		</script>
		<script src="https://www.youtube.com/iframe_api" async></script>
	    <!-- Cookie Consent & Google Analytics -->
    <script type="text/javascript">
    var _iub = _iub || [];
    _iub.csConfiguration = {
        "siteId": 4520027,
        "cookiePolicyId": 73713693,
        "lang": "en",
        "storage": { "useSiteId": true },
        "googleAnalyticsId": "G-RY0B6QFYPN",
        "consentOnContinuedBrowsing": true
    };
    </script>
    <script type="text/javascript" src="https://cs.iubenda.com/autoblocking/4520027.js"></script>
    <script type="text/javascript" src="//cdn.iubenda.com/cs/gpp/stub.js"></script>
    <script type="text/javascript" src="//cdn.iubenda.com/cs/iubenda_cs.js" charset="UTF-8" async></script>
    </head>
	<body>
		<div id="bg" aria-hidden="true"></div>

		<header class="header">
			<div class="header-content">
				<div class="brand-block">
					<p class="eyebrow">Cinematic archive</p>
					<h1>Ruh Al Tarikh</h1>
					<p class="header-tagline">Uncovering truth through Islamic history, scripture, and contested ideas.</p>
				</div>
				<div class="header-actions">
					<button id="mobileMenuToggle" class="icon-button mobile-toggle" type="button" aria-label="Toggle mobile menu">
						<i class="fa-solid fa-bars"></i>
					</button>
					<button id="watchLaterBadge" class="pill-button accent" type="button" aria-label="Open watch later list">
						<i class="fa-regular fa-bookmark" aria-hidden="true"></i>
						<span>Watch Later</span>
						<strong id="watchLaterCount">0</strong>
					</button>
					<button id="dashboardBtn" class="pill-button" type="button" aria-label="Open viewing dashboard">
						<i class="fa-solid fa-chart-simple" aria-hidden="true"></i>
						<span>Dashboard</span>
					</button>
					<button id="studioToggleBtn" class="pill-button accent" type="button" aria-label="Toggle Creator Studio">
						<i class="fa-solid fa-video" aria-hidden="true"></i>
						<span>Studio</span>
					</button>
					<a
						href="https://www.youtube.com/@Ruh-Al-Tarikh"
						target="_blank"
						rel="noopener noreferrer"
						class="icon-button"
						aria-label="Visit YouTube channel"
						title="YouTube Channel"
					>
						<i class="fa-brands fa-youtube"></i>
					</a>
					<button id="darkModeToggle" class="icon-button" type="button" aria-label="Toggle theme" title="Toggle theme (T)">
						<i class="fa-regular fa-moon" aria-hidden="true"></i>
					</button>
				</div>
			</div>
			<nav id="mobileNav" class="mobile-nav" aria-hidden="true">
				<div class="mobile-nav-content">
					<button
						class="mobile-nav-link"
						onclick="
							document.querySelector('[data-cat=all]').click();
							document.getElementById('mobileMenuToggle').click();
						"
					>
						<i class="fa-solid fa-film"></i> All Episodes
					</button>
					<button
						class="mobile-nav-link"
						onclick="
							document.getElementById('watchLaterBadge').click();
							document.getElementById('mobileMenuToggle').click();
						"
					>
						<i class="fa-solid fa-bookmark"></i> Watch Later
					</button>
					<button
						class="mobile-nav-link"
						onclick="
							document.getElementById('dashboardBtn').click();
							document.getElementById('mobileMenuToggle').click();
						"
					>
						<i class="fa-solid fa-chart-simple"></i> Dashboard
					</button>
				</div>
			</nav>
		</header>

		<main id="app-root" class="fade-in">
			<section class="search-filter-section" aria-label="Browse controls">
				<div class="search-panel">
					<label class="search-label" for="searchInput">Search the archive</label>
					<div class="search-container">
						<i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
						<input
							type="text"
							id="searchInput"
							placeholder="Search episodes, topics, people, or places (/ to focus)"
							autocomplete="off"
							aria-autocomplete="list"
							aria-controls="searchSuggestions"
						/>
						<button
							id="clearSearch"
							class="clear-search"
							type="button"
							aria-label="Clear search"
							title="Clear search (Esc)"
							style="display: none"
						>
							<i class="fa-solid fa-xmark" aria-hidden="true"></i>
						</button>
						<div id="searchSuggestions" class="search-suggestions" role="listbox" aria-hidden="true"></div>
					</div>
				</div>

				<nav class="filter-chips" aria-label="Filter by category">
					<button class="chip active" data-cat="all">All Episodes</button>
					<button class="chip" data-cat="quran">Quranic Studies</button>
					<button class="chip" data-cat="prophecy">Prophecy</button>
					<button class="chip" data-cat="history">History</button>
					<button class="chip" data-cat="discussion">Discussion</button>
					<button class="chip chip-clear" id="clearFilters" style="display: none">
						<i class="fa-solid fa-circle-xmark"></i> Clear All
					</button>
				</nav>
			</section>

			<div id="loading" class="loading-state">
				<div class="spinner"></div>
				<p>Consulting the archives...</p>
			</div>

			<div id="error" class="error-container" style="display: none">
				<i class="fa-solid fa-triangle-exclamation"></i>
				<p id="error-msg">Failed to connect to the archive.</p>
				<button id="retryBtn" class="primary-button">Retry Connection</button>
			</div>

			<section id="hero" class="hero" style="display: none">
				<div class="ornament ornament-1"></div>
				<div class="ornament ornament-2"></div>
				<div class="ornament ornament-3"></div>
				<div id="hero-bg" class="hero-bg"></div>
				<div class="hero-overlay">
					<div class="hero-main">
						<p class="overlay-kicker"><span id="hero-category"></span> • <span id="hero-date"></span></p>
						<h2 id="hero-title"></h2>
						<p id="hero-desc" class="hero-desc"></p>
						<div class="hero-actions">
							<button id="hero-btn" class="primary-button"><i class="fa-solid fa-play"></i> Watch Now</button>
							<button id="hero-save" class="secondary-button"><i class="fa-regular fa-bookmark"></i> Save for Later</button>
						</div>
					</div>
					<aside class="hero-aside">
						<div class="highlight-card">
							<i class="fa-solid fa-clock-rotate-left"></i>
							<div>
								<h3 id="highlight-latest-title">History</h3>
								<p id="highlight-latest-copy">Deep dives into the past</p>
							</div>
						</div>
						<div class="highlight-card">
							<i class="fa-solid fa-scroll"></i>
							<div>
								<h3>Scripture</h3>
								<p>Analysis of texts</p>
							</div>
						</div>
						<div class="highlight-card">
							<i class="fa-solid fa-bolt"></i>
							<div>
								<h3>Truth</h3>
								<p>Uncovering facts</p>
							</div>
						</div>
					</aside>
				</div>
			</section>

			<section id="empty-history" class="content-section" style="display: none">
				<article class="empty-state-card">
					<i class="fa-solid fa-clapperboard"></i>
					<h3>No viewing history yet</h3>
					<p class="section-copy">Start an episode and your progress will be tracked here.</p>
				</article>
			</section>

			<section id="continue-block" class="content-section" style="display: none">
				<div class="section-heading">
					<h2 class="section-title">Continue Watching</h2>
					<p class="section-copy">Jump back into unfinished episodes.</p>
				</div>
				<div id="continue-row" class="row"></div>
			</section>

			<section id="trending-block" class="content-section" style="display: none">
				<div class="section-heading">
					<h2 class="section-title">Trending in the Archive</h2>
					<p class="section-copy">A blend of recent drops and frequently resumed talks.</p>
				</div>
				<div id="trending-row" class="row"></div>
			</section>

			<section id="recommended-block" class="content-section" style="display: none">
				<div class="section-heading">
					<h2 class="section-title">Recommended For You</h2>
					<p class="section-copy">Episodes based on your viewing history.</p>
				</div>
				<div id="recommended-row" class="row"></div>
			</section>

			<section class="content-section">
				<div class="section-heading">
					<h2 class="section-title">Episodes</h2>
					<p class="section-copy">Every upload, searchable and filterable in one place.</p>
				</div>
				<div id="results-meta" class="results-meta"></div>
				<div id="grid" class="grid"></div>
				<div id="loadMoreContainer" class="load-more-container" style="display: none">
					<button id="loadMoreBtn" class="primary-button" type="button">Load More Episodes</button>
				</div>
			</section>
		</main>

		<!-- Creator Studio Shell -->
		<main id="studio-root" class="fade-in" style="display: none;">
			<div class="studio-layout">
				<aside class="studio-sidebar">
					<div class="studio-sidebar-header">
						<h2>Creator Workspace</h2>
					</div>
					<nav class="studio-nav">
						<button class="studio-nav-btn active" data-tab="projects"><i class="fa-solid fa-folder-open"></i> Projects</button>
						<button class="studio-nav-btn" data-tab="planner"><i class="fa-regular fa-calendar-days"></i> Planner</button>
						<button class="studio-nav-btn" data-tab="dashboard"><i class="fa-solid fa-chart-line"></i> Insights</button>
						<button class="studio-nav-btn" data-tab="islamic"><i class="fa-solid fa-book-quran"></i> References</button>
					</nav>
					<div class="studio-sidebar-footer">
						<button id="newProjectBtn" class="primary-button full-width"><i class="fa-solid fa-plus"></i> New Video</button>
					</div>
				</aside>

				<div class="studio-main">
					<!-- Project View (Active when inside a project) -->
					<div id="active-project-view" style="display: none;">
						<header class="project-header">
							<div class="project-title-area">
								<button id="backToProjectsBtn" class="icon-button"><i class="fa-solid fa-arrow-left"></i></button>
								<h2 id="current-project-title">Untitled Video</h2>
							</div>
							<div class="project-progress">
								<span class="progress-step active">Researching</span>
								<i class="fa-solid fa-chevron-right"></i>
								<span class="progress-step">Writing</span>
								<i class="fa-solid fa-chevron-right"></i>
								<span class="progress-step">Recording</span>
								<i class="fa-solid fa-chevron-right"></i>
								<span class="progress-step">Editing</span>
								<i class="fa-solid fa-chevron-right"></i>
								<span class="progress-step">Published</span>
							</div>
							<div class="project-actions">
								<button id="exportProjectBtn" class="secondary-button"><i class="fa-solid fa-file-export"></i> Export</button>
							</div>
						</header>

						<nav class="project-tabs">
							<button class="project-tab-btn active" data-ptab="research">Research</button>
							<button class="project-tab-btn" data-ptab="script">Script</button>
							<button class="project-tab-btn" data-ptab="voice">Voiceover</button>
							<button class="project-tab-btn" data-ptab="seo">SEO & Publish</button>
							<button class="project-tab-btn" data-ptab="repurpose">Repurpose</button>
						</nav>

						<div class="project-content-area">
							<!-- Project Tab Contents injected by JS -->
							<div id="ptab-research" class="ptab-content active"></div>
							<div id="ptab-script" class="ptab-content"></div>
							<div id="ptab-voice" class="ptab-content"></div>
							<div id="ptab-seo" class="ptab-content"></div>
							<div id="ptab-repurpose" class="ptab-content"></div>
						</div>
					</div>

					<!-- Main Views (Projects, Planner, Dashboard, Islamic References) -->
					<div id="studio-view-projects" class="studio-view active">
						<div class="section-heading">
							<h2 class="section-title">Your Projects</h2>
							<p class="section-copy">Manage your upcoming and past videos.</p>
						</div>
						<div class="studio-projects-grid" id="studioProjectsList">
							<!-- Populated by JS -->
						</div>
					</div>
					<div id="studio-view-planner" class="studio-view" style="display: none;"></div>
					<div id="studio-view-dashboard" class="studio-view" style="display: none;"></div>
					<div id="studio-view-islamic" class="studio-view" style="display: none;"></div>
				</div>
			</div>
		</main>


		<!-- Modal Player -->
		<div id="modal" class="modal" aria-hidden="true">
			<div class="modal-content">
				<button id="close" class="close-btn" type="button" aria-label="Close player">
					<i class="fa-solid fa-xmark" aria-hidden="true"></i>
				</button>
				<div class="modal-body">
					<div class="video-container">
						<iframe
							id="player"
							title="YouTube player"
							allow="autoplay; encrypted-media; fullscreen; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>
					<div class="video-sidebar">
						<button id="toggleTranscript" class="sidebar-btn" type="button" aria-label="Toggle transcript panel" title="View episode notes">
							<i class="fa-solid fa-note-sticky" aria-hidden="true"></i>
						</button>
						<button id="shareEpisode" class="sidebar-btn" type="button" aria-label="Share episode" title="Share this episode">
							<i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
						</button>
					</div>

					<!-- Transcript Panel -->
					<div id="transcriptPanel" class="transcript-panel" aria-hidden="true">
						<div class="transcript-header">
							<h3>Episode Notes</h3>
							<button id="closeTranscript" class="close-transcript" type="button" aria-label="Close transcript">
								<i class="fa-solid fa-xmark" aria-hidden="true"></i>
							</button>
						</div>
						<div id="transcriptContent" class="transcript-content">
							<p class="transcript-placeholder">Transcript & notes coming soon for this episode.</p>
						</div>
					</div>

					<!-- Share Panel -->
					<div id="sharePanel" class="share-panel" aria-hidden="true">
						<div class="share-header">
							<h3>Share Episode</h3>
							<button id="closeShare" class="close-share" type="button" aria-label="Close share">
								<i class="fa-solid fa-xmark" aria-hidden="true"></i>
							</button>
						</div>
						<div class="share-content">
							<div class="share-link-block">
								<label for="shareLink">Copy link</label>
								<div class="copy-input-group">
									<input type="text" id="shareLink" readonly />
									<button id="copyLinkBtn" class="copy-btn" type="button">Copy</button>
								</div>
							</div>
							<div class="share-social">
								<p>Share on</p>
								<div class="social-buttons">
									<button id="shareTwitter" class="social-btn twitter" type="button" aria-label="Share on Twitter">
										<i class="fa-brands fa-twitter"></i>
									</button>
									<button id="shareFacebook" class="social-btn facebook" type="button" aria-label="Share on Facebook">
										<i class="fa-brands fa-facebook"></i>
									</button>
									<button id="shareWhatsApp" class="social-btn whatsapp" type="button" aria-label="Share on WhatsApp">
										<i class="fa-brands fa-whatsapp"></i>
									</button>
								</div>
							</div>
						</div>
					</div>
				</div>
				<h2 id="video-title" class="modal-title"></h2>
			</div>
		</div>

		<!-- Watch Later Overlay -->
		<section id="watchLaterPage" class="watch-later-page" style="display: none" aria-hidden="true">
			<div class="watch-later-shell">
				<div class="watch-later-header">
					<div>
						<p class="overlay-kicker">Saved queue</p>
						<h2>Watch Later</h2>
					</div>
					<button id="closeWatchLater" class="icon-button" type="button" aria-label="Close watch later">
						<i class="fa-solid fa-xmark" aria-hidden="true"></i>
					</button>
				</div>
				<div id="watchLaterContainer" class="overlay-grid"></div>
			</div>
		</section>

		<!-- Dashboard Modal -->
		<section id="dashboardModal" class="dashboard-modal" style="display: none" aria-hidden="true">
			<div class="dashboard-content">
				<div class="dashboard-header">
					<div>
						<p class="overlay-kicker">Viewer snapshot</p>
						<h2>Archive Dashboard</h2>
					</div>
					<button id="closeDashboard" class="icon-button" type="button" aria-label="Close dashboard">
						<i class="fa-solid fa-xmark" aria-hidden="true"></i>
					</button>
				</div>
				<div class="dashboard-stats">
					<article class="stat-card">
						<h3>Episodes Loaded</h3>
						<p id="dashboard-total">0</p>
					</article>
					<article class="stat-card">
						<h3>Saved for Later</h3>
						<p id="dashboard-saved">0</p>
					</article>
					<article class="stat-card">
						<h3>Active Sessions</h3>
						<p id="dashboard-progress">0</p>
					</article>
					<article class="stat-card">
						<h3>Hours Estimated</h3>
						<p id="dashboard-hours">0.0h</p>
					</article>
				</div>
				<div class="dashboard-panels">
					<section class="dashboard-panel">
						<h3>Category Spread</h3>
						<div id="dashboardCategories" class="dashboard-list"></div>
					</section>
					<section class="dashboard-panel">
						<h3>Resume Queue</h3>
						<div id="dashboardResumeList" class="dashboard-list"></div>
					</section>
				</div>
			</div>
		</section>

		<!-- Toast Notification -->
		<div id="toast" class="toast" aria-live="polite"></div>

		<!-- Keyboard Shortcuts Hints -->
		<div id="keyboardHints" class="keyboard-hints" aria-hidden="true">
			<div class="hints-content">
				<h3>Keyboard Shortcuts</h3>
				<ul>
					<li><kbd>/</kbd> Focus search</li>
					<li><kbd>J</kbd> Previous episode</li>
					<li><kbd>K</kbd> Next episode</li>
					<li><kbd>Esc</kbd> Close modals</li>
					<li><kbd>&#8593;&#8595;&#8592;&#8594;</kbd> Navigate grid</li>
				</ul>
				<button id="closeHints" type="button">Got it</button>
			</div>
		</div>

		<footer class="footer">
			<div class="footer-content">
				<div class="footer-brand">
					<h2 class="footer-logo">Ruh Al Tarikh</h2>
					<p class="footer-tagline">Uncovering truth through Islamic history, scripture, and contested ideas.</p>
				</div>
				<nav class="footer-nav" aria-label="Footer Navigation">
					<div class="footer-group">
						<h3>Archive</h3>
						<ul>
							<li>
								<a
									href="#"
									onclick="
										document.querySelector('[data-cat=all]').click();
										return false;
									"
									>All Episodes</a
								>
							</li>
							<li>
								<a
									href="#"
									onclick="
										document.querySelector('[data-cat=quran]').click();
										return false;
									"
									>Quranic Studies</a
								>
							</li>
							<li>
								<a
									href="#"
									onclick="
										document.querySelector('[data-cat=history]').click();
										return false;
									"
									>History</a
								>
							</li>
						</ul>
					</div>
					<div class="footer-group">
						<h3>Tools</h3>
						<ul>
							<li>
								<a
									href="#"
									onclick="
										document.getElementById('watchLaterBadge').click();
										return false;
									"
									>Watch Later</a
								>
							</li>
							<li>
								<a
									href="#"
									onclick="
										document.getElementById('dashboardBtn').click();
										return false;
									"
									>Dashboard</a
								>
							</li>
							<li>
								<a
									href="#"
									onclick="
										document.getElementById('darkModeToggle').click();
										return false;
									"
									>Toggle Theme</a
								>
							</li>
						</ul>
					</div>
					<div class="footer-group">
