# Environment variables template - Copy to .env for local development

# Node Environment
NODE_ENV=development

# Docker & Deployment
DOCKER_ENV=development
DOCKER_COMPOSE_PROJECT=yt-studio

# API Configuration
API_URL=http://localhost:8787
API_PORT=3000

# YouTube API Key (get from Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Generative AI (Gemini)
GOOGLE_API_KEY=your_google_generative_ai_key_here

# OpenAI API (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face (optional)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Database Configuration (optional)
DATABASE_URL=your_database_url_here

# Cloudflare Workers (use 'wrangler login' - DO NOT hardcode tokens!)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# GitHub Actions (for CI/CD automation)
GITHUB_TOKEN=your_github_token_here

# Deployment
DEPLOY_ENV=development
LOG_LEVEL=info
