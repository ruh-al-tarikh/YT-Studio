# Environment variables for YT Studio
# Copy to .env and fill in your values
# @defaultRequired=infer @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)

# example env variable injected by `varlock init` ⚠️ DELETE THIS ITEM! ⚠️
# @required @sensitive @example="example value"
EXAMPLE_ITEM="delete me!"
# YouTube API Configuration
# @sensitive
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=UCrjJP_SHUeCmqpTSHJCXkdA

# Node Environment
NODE_ENV=development

# Google Generative AI (Gemini)
# @sensitive
GOOGLE_API_KEY=your_google_generative_ai_key_here

# Cloudflare Workers
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
# @sensitive
CLOUDFLARE_API_TOKEN=your_api_token_here

# Docker
DOCKER_ENV=development
DOCKER_COMPOSE_PROJECT=yt-studio

# API Configuration
# @type=url
API_URL=https://yt-studio-production.ruhdevopsytstudio.workers.dev
# @type=port
API_PORT=3000

# Deployment
DEPLOY_ENV=development
LOG_LEVEL=info

