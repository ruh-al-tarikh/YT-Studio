{
  "name": "ytstudio",
  "main": "src/youtube-worker.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "env": {
    "production": {
      "name": "ytstudio",
      "vars": {
        "ENVIRONMENT": "production",
        "CHANNEL_ID": "UCrjJP_SHUeCmqpTSHJCXkdA"
      }
    }
  },
  "vars": {
    "ENVIRONMENT": "development",
    "CHANNEL_ID": "UCrjJP_SHUeCmqpTSHJCXkdA"
  },
  "observability": {
    "enabled": true
  }
}
